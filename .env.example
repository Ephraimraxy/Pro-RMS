# ─────────────────────────────────────────────
# CSS Group RMS — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Auth ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-64-char-random-hex"

# ── Super Admin ───────────────────────────────
SUPER_ADMIN_ACCESS_CODE="your-super-admin-code"
SUPER_ADMIN_MFA_PIN="123456"

# ── Initial Admin Password (seed only) ────────
INITIAL_ADMIN_PASSWORD="change-me-on-first-login"

# ── Cryptographic Signing ─────────────────────
# Option A: Provide pre-generated Ed25519 PEM keys (base64 or PEM)
SIGNING_PRIVATE_KEY=""
SIGNING_PUBLIC_KEY=""

# Option B: Master key for per-department key derivation (32 bytes hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIGNING_MASTER_KEY=""

# ── File Storage — Bunny CDN (primary) ────────
BUNNY_STORAGE_ZONE="your-zone-name"
BUNNY_API_KEY="your-bunny-api-key"
BUNNY_STORAGE_ENDPOINT="https://storage.bunnycdn.com"

# ── File Storage — AWS S3 (fallback) ──────────
# S3_BUCKET=""
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""        # for S3-compatible providers

# ── Email ─────────────────────────────────────
# Option A: Gmail with App Password
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Option B: Generic SMTP
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE=false

MAIL_FROM="CSS RMS <noreply@cssgroup.local>"

# ── App ───────────────────────────────────────
NODE_ENV="production"
PORT=3000
APP_BASE_URL="https://your-app.up.railway.app"
CORS_ORIGIN="https://your-app.up.railway.app"
TRUST_PROXY=1

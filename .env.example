# ─────────────────────────────────────────────
# CSS Group RMS — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Auth ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-64-char-random-hex"

# ── Super Admin ───────────────────────────────
# These are the ONLY source of truth for Super Admin login.
# Changing them in Railway takes effect on next deploy — no DB changes needed.
SUPER_ADMIN_ACCESS_CODE="your-super-admin-code"
SUPER_ADMIN_MFA_PIN="your-6-digit-pin"

# ── Special Department Access Codes (optional) ─
# Initial codes used only when these departments are first created.
# After creation, rotate via Admin UI → Department Manager → Reset Code.
# If not set, defaults (GM-2026 / CEO-2026 / ICC-2026) are used at first boot.
GM_ACCESS_CODE="GM-2026"
CEO_ACCESS_CODE="CEO-2026"
ICC_ACCESS_CODE="ICC-2026"

# ── Initial Admin Password (seed only) ────────
INITIAL_ADMIN_PASSWORD="change-me-on-first-login"

# ── Cryptographic Signing ─────────────────────
# Option A: Provide pre-generated Ed25519 PEM keys (base64 or PEM)
SIGNING_PRIVATE_KEY=""
SIGNING_PUBLIC_KEY=""

# Option B: Master key for per-department key derivation (32 bytes hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIGNING_MASTER_KEY=""

# ── File Storage — Cloudflare R2 / S3 ──────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET_NAME="your-bucket"
R2_PUBLIC_URL="https://your-public-url.r2.dev"

# ── Email ─────────────────────────────────────
# Option A: Gmail with App Password
GMAIL_USER="you@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Option B: Generic SMTP
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE=false

MAIL_FROM="CSS RMS <noreply@cssgroup.local>"

# ── App ───────────────────────────────────────
NODE_ENV="production"
PORT=3000
APP_BASE_URL="https://your-app.up.railway.app"
CORS_ORIGIN="https://your-app.up.railway.app"
TRUST_PROXY=1

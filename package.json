{
  "name": "RMS",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend:install": "npm --prefix rms_frontend ci --cache ./.npm-cache --legacy-peer-deps --no-audit --no-fund --loglevel=warn",
    "build": "prisma generate --schema=rms_backend/prisma/schema.prisma && npm run frontend:install && npm --prefix rms_frontend run build",
    "start": "node serve.js",
    "seed": "node rms_backend/prisma/seed.js",
    "deploy-sync": "prisma db push --schema=rms_backend/prisma/schema.prisma && node rms_backend/prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.886.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "web-push": "^3.6.7",
    "xss": "^1.0.15",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=20"
  }
}

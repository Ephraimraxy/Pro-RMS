{
  "name": "css-rms",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema=rms_backend/prisma/schema.prisma && cd rms_frontend && npm install --legacy-peer-deps && npm run build",
    "build": "cd rms_frontend && npm run build",
    "start": "node serve.js",
    "seed": "node rms_backend/prisma/seed.js",
    "deploy-sync": "prisma db push --schema=rms_backend/prisma/schema.prisma && node rms_backend/prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.886.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "xss": "^1.0.15",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=20"
  }
}

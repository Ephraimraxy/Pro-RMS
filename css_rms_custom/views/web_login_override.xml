<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override the general web layout to change Favicon and Title -->
    <template id="custom_web_layout" inherit_id="web.layout" priority="99">
        <!-- The default title block -->
        <xpath expr="//title" position="replace">
            <title>CSS RMS Enterprise</title>
        </xpath>
        <!-- The default favicon -->
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <link type="image/x-icon" rel="shortcut icon" href="/css_rms_custom/static/favicon.svg"/>
        </xpath>
    </template>

    <!-- Override the Login and Database Manager Layout -->
    <template id="custom_login_layout" inherit_id="web.login_layout" priority="99">
        <!-- Replaces the logo div -->
        <xpath expr="//img[contains(@t-attf-src, 'company_logo')]/.." position="replace">
            <div class="text-center pb-3 border-bottom mb-4">
                <img src="/css_rms_custom/static/hero.png" alt="CSS RMS Logo" style="max-height: 120px; max-width: 100%; width: auto; margin: 0 auto; display: block;" />
            </div>
        </xpath>
        <!-- Replaces the "Powered by Odoo" footer -->
        <xpath expr="//div[@t-if='not disable_footer']" position="replace">
            <div class="text-center small mt-4 pt-3 border-top text-muted" t-if="not disable_footer">
                CSS RMS Enterprise | Powered by CSS Group Holding
            </div>
        </xpath>
    </template>
</odoo>

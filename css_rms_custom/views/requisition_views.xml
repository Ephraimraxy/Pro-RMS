<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_css_rms_requisition_tree" model="ir.ui.view">
        <field name="name">css.rms.requisition.tree</field>
        <field name="model">css.rms.requisition</field>
        <field name="arch" type="xml">
            <list string="Requisitions">
                <field name="name"/>
                <field name="user_id"/>
                <field name="department_id"/>
                <field name="type"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_css_rms_requisition_form" model="ir.ui.view">
        <field name="name">css.rms.requisition.form</field>
        <field name="model">css.rms.requisition</field>
        <field name="arch" type="xml">
            <form string="Requisition">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" invisible="state != 'pending'"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="state != 'draft'"/>
                            <field name="department_id"/>
                            <field name="type" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="stage_id" readonly="1" invisible="not stage_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Describe the purpose of this requisition..." readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_css_rms_stage_tree" model="ir.ui.view">
        <field name="name">css.rms.stage.tree</field>
        <field name="model">css.rms.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="role_id"/>
                <field name="min_amount"/>
                <field name="max_amount"/>
                <field name="is_final"/>
            </list>
        </field>
    </record>

    <record id="action_css_rms_stage" model="ir.actions.act_window">
        <field name="name">Approval Stages</field>
        <field name="res_model">css.rms.stage</field>
        <field name="view_mode">list</field>
    </record>

    <record id="action_css_rms_requisition_to_approve" model="ir.actions.act_window">
        <field name="name">To Approve</field>
        <field name="res_model">css.rms.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No requisitions pending your approval.
            </p>
        </field>
    </record>

    <record id="action_css_rms_requisition_all" model="ir.actions.act_window">
        <field name="name">All Requisitions</field>
        <field name="res_model">css.rms.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                View and manage all organization requisitions here.
            </p>
        </field>
    </record>

    <record id="action_css_rms_requisition" model="ir.actions.act_window">
        <field name="name">My Requisitions</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">css.rms.requisition</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('user_id', '=', uid)]</field>
    </record>

    <menuitem id="menu_css_rms_root" name="Requisitions" web_icon="css_rms_custom,static/description/icon.png"/>
    <menuitem id="menu_css_rms_my" name="My Dashboard" parent="menu_css_rms_root" sequence="10"/>
    <menuitem id="menu_css_rms_requisition" name="My Requests" parent="menu_css_rms_my" sequence="1" action="action_css_rms_requisition"/>
    <menuitem id="menu_css_rms_to_approve" name="To Approve" parent="menu_css_rms_my" sequence="2" action="action_css_rms_requisition_to_approve"/>
    
    <menuitem id="menu_css_rms_management" name="Management" parent="menu_css_rms_root" sequence="20" groups="group_rms_admin,group_rms_audit,group_rms_gm,group_rms_chairman,group_rms_finance"/>
    <menuitem id="menu_css_rms_all" name="All Requisitions" parent="menu_css_rms_management" sequence="1" action="action_css_rms_requisition_all"/>

    <menuitem id="menu_css_rms_config" name="Configuration" parent="menu_css_rms_root" sequence="100" groups="group_rms_manager"/>
    <menuitem id="menu_css_rms_stage" name="Approval Stages" parent="menu_css_rms_config" action="action_css_rms_stage"/>
</odoo>

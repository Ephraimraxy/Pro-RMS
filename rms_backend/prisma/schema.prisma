// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String
  password     String
  role         String        @default("staff")
  mfaEnabled   Boolean       @default(false)
  mfaSecret    String?       
  departmentId Int?
  department   Department?   @relation(fields: [departmentId], references: [id])
  requisitions Requisition[]
  memos        Memo[]
  activityLogs ActivityLog[]
  notifications Notification[]
  fileAccessLogs FileAccessLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Department {
  id             Int           @id @default(autoincrement())
  code           String?       @unique // Optional short code
  name           String        @unique
  type           String        @default("Operational") // "Strategic", "Operational"
  accessCode     String?       // For departmental login
  parentId       Int?
  parent         Department?   @relation("Hierarchy", fields: [parentId], references: [id])
  subDepartments Department[]  @relation("Hierarchy")
  users          User[]
  requisitions   Requisition[]
  memos          Memo[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Requisition {
  id           Int        @id @default(autoincrement())
  title        String
  type         String     // "Cash", "Material", "Memo"
  amount       Float?
  description  String?
  status       String     @default("pending")
  creatorId    Int
  creator      User       @relation(fields: [creatorId], references: [id])
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  attachments  Attachment[]
  content      String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Memo {
  id           Int        @id @default(autoincrement())
  title        String
  content      String     @db.Text
  status       String     @default("draft") // "draft", "published", "archived"
  creatorId    Int
  creator      User       @relation(fields: [creatorId], references: [id])
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  timestamp DateTime @default(now())
}

model RequisitionType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
}

model WorkflowStage {
  id        Int      @id @default(autoincrement())
  sequence  Int      @unique
  name      String
  role      String   
  threshold Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  content    String
  link       String?  
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Attachment {
  id            Int           @id @default(autoincrement())
  filename      String
  path          String
  fileType      String
  requisitionId Int?
  requisition   Requisition?  @relation(fields: [requisitionId], references: [id])
  accessLogs    FileAccessLog[]
  createdAt     DateTime      @default(now())
}

model FileAccessLog {
  id           Int        @id @default(autoincrement())
  attachmentId Int
  attachment   Attachment @relation(fields: [attachmentId], references: [id])
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  timestamp    DateTime   @default(now())
}

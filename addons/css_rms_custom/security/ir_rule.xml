<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule: Users see their own requisitions -->
        <record id="rule_css_rms_requisition_user" model="ir.rule">
            <field name="name">Show Only Own Requisitions</field>
            <field name="model_id" ref="model_css_rms_requisition"/>
            <field name="groups" eval="[(4, ref('group_rms_user'))]"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('message_partner_ids', 'in', [user.partner_id.id])]</field>
        </record>

        <!-- Rule: Departmental Managers (HOD) see their department's requisitions -->
        <record id="rule_css_rms_requisition_department" model="ir.rule">
            <field name="name">HOD: Show Departmental Requisitions</field>
            <field name="model_id" ref="model_css_rms_requisition"/>
            <field name="groups" eval="[(4, ref('group_rms_hod'))]"/>
            <field name="domain_force">[('department_id', '=', user.department_id.id)]</field>
        </record>

        <!-- Rule: Higher Authorities see everything but filtered by Dashboard -->
        <record id="rule_css_rms_requisition_all" model="ir.rule">
            <field name="name">Admin/Management: Show All Requisitions</field>
            <field name="model_id" ref="model_css_rms_requisition"/>
            <field name="groups" eval="[(4, ref('group_rms_admin')), (4, ref('group_rms_audit')), (4, ref('group_rms_gm')), (4, ref('group_rms_chairman')), (4, ref('group_rms_finance'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- Rule: System Administrator sees everything -->
        <record id="rule_css_rms_requisition_root" model="ir.rule">
            <field name="name">RMS Admin: Full Control</field>
            <field name="model_id" ref="model_css_rms_requisition"/>
            <field name="groups" eval="[(4, ref('group_rms_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>

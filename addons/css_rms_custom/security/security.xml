<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_css_rms" model="ir.module.category">
        <field name="name">Requisition Management (RMS)</field>
        <field name="description">Helps manage internal requisitions and approvals.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_rms_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_rms_admin" model="res.groups">
        <field name="name">Administration</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_user'))]"/>
    </record>

    <record id="group_rms_audit" model="res.groups">
        <field name="name">Audit</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_user'))]"/>
    </record>

    <record id="group_rms_hod" model="res.groups">
        <field name="name">Head of Dept</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_user'))]"/>
    </record>

    <record id="group_rms_hhr" model="res.groups">
        <field name="name">HR/Administration (HHR/A)</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_user'))]"/>
    </record>

    <record id="group_rms_gm" model="res.groups">
        <field name="name">General Manager (GM)</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_user'))]"/>
    </record>

    <record id="group_rms_chairman" model="res.groups">
        <field name="name">Chairman</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_user'))]"/>
    </record>

    <record id="group_rms_finance" model="res.groups">
        <field name="name">Finance Controller (FC)</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_user'))]"/>
    </record>

    <record id="group_rms_manager" model="res.groups">
        <field name="name">System Administrator</field>
        <field name="category_id" ref="module_category_css_rms"/>
        <field name="implied_ids" eval="[(4, ref('group_rms_chairman')), (4, ref('group_rms_finance')), (4, ref('base.group_system'))]"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="stage_admin" model="css.rms.stage">
            <field name="name">Administration Review</field>
            <field name="sequence">10</field>
            <field name="role_id" ref="group_rms_admin"/>
        </record>

        <record id="stage_audit" model="css.rms.stage">
            <field name="name">Audit Review</field>
            <field name="sequence">20</field>
            <field name="role_id" ref="group_rms_audit"/>
        </record>

        <record id="stage_hod" model="css.rms.stage">
            <field name="name">HOD Approval</field>
            <field name="sequence">30</field>
            <field name="role_id" ref="group_rms_hod"/>
            <field name="max_amount">100000</field> 
        </record>

        <record id="stage_hhr" model="css.rms.stage">
            <field name="name">HR/Admin Approval</field>
            <field name="sequence">40</field>
            <field name="role_id" ref="group_rms_hhr"/>
            <field name="min_amount">100000</field>
            <field name="max_amount">500000</field>
        </record>

        <record id="stage_gm" model="css.rms.stage">
            <field name="name">GM Approval</field>
            <field name="sequence">50</field>
            <field name="role_id" ref="group_rms_gm"/>
            <field name="min_amount">500000</field>
            <field name="max_amount">2000000</field>
        </record>

        <record id="stage_chairman" model="css.rms.stage">
            <field name="name">Chairman Approval</field>
            <field name="sequence">60</field>
            <field name="role_id" ref="group_rms_chairman"/>
            <field name="min_amount">2000000</field>
        </record>

        <record id="stage_finance" model="css.rms.stage">
            <field name="name">Finance Processing</field>
            <field name="sequence">100</field>
            <field name="role_id" ref="group_rms_finance"/>
            <field name="is_final" eval="True"/>
        </record>
    </data>
</odoo>

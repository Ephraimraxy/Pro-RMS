<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="web.UpgradeDialog">
        <Dialog title.translate="CSS-RMS">
            <div role="status" class="text-center p-4">
                This feature is managed by your system administrator.
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="this.props.close">Close</button>
            </t>
        </Dialog>
    </t>
</templates>
